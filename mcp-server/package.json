    "test": "npm run build && node --test test/enhancements/",
    "test:enhancements": "npm run build && node --test test/enhancements/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}