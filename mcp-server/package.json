{
  "name": "cognizapp-provider-mcp",
  "version": "1.3.0",
  "description": "MCP server for controlling the CognizApp Provider support system",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cognizapp-provider-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
